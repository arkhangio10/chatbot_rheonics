# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Google Gemini (used for PDF vision, embeddings, and answering)
GEMINI_API_KEY=your_gemini_api_key_here

# Paths (defaults work for the standard folder layout)
CHROMA_PERSIST_DIR=./vector_store
KNOWLEDGE_BASE_DIR=./knowledge_base
PDFS_DIR=./pdfs
NOTES_DIR=./my_notes

# Models (upgrade here when stable versions change)
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_ANSWER_MODEL=gemini-2.5-flash
